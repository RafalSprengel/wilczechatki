

# === Stripe ===
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=   # Publiczny klucz Stripe (frontend)
STRIPE_SECRET_KEY=               # Sekretny klucz Stripe (backend)
STRIPE_WEBHOOK_SECRET=           # Sekret do weryfikacji webhooków Stripe

# === MongoDB ===
MONGODB_URI=                     # Connection string do MongoDB

# === Resend (maile) ===
RESEND_API_KEY=                  # Klucz API do wysyłki maili przez Resend

# === Better Auth ===
BETTER_AUTH_SECRET=              # Sekret do własnej autoryzacji
BETTER_AUTH_URL=                 # URL do serwera autoryzacji

